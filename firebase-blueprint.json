{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" }
      },
      "required": ["uid", "email", "role"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "A product saved to the user's wishlist",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product" },
        "userId": { "type": "string", "description": "The ID of the user who saved it" },
        "addedAt": { "type": "string", "format": "date-time", "description": "When it was added" }
      },
      "required": ["productId", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile data"
    },
    "/users/{userId}/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User's private wishlist"
    }
  }
}
